# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=td_checker
DB_USER=td_user
DB_PASSWORD=CHANGE_ME_strong_password

# Connection pool sizes
DB_POOL_MIN=2
DB_POOL_MAX=10

# Flask server (optional overrides — defaults shown)
# SERVER_PORT=8000
